{
  "name": "js-bot-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "test": "vitest run",
    "test:watch": "vitest",
    "bdd": "node scripts/bdd-smoke.mjs",
    "bdd:setup": "cucumber-js features/game_setup.feature --import tests/bdd/**/*.js",
    "bdd:movement": "cucumber-js features/bot_movement.feature --import tests/bdd/**/*.js",
    "bdd:map": "cucumber-js features/map_interactions.feature --import tests/bdd/**/*.js",
    "bdd:program": "cucumber-js features/program_execution.feature --import tests/bdd/**/*.js",
    "bdd:features": "cucumber-js features/**/*.feature --import tests/bdd/**/*.js",
    "verify": "npm test && npm run bdd:features && npm run e2e && npm run build",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.0.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.2"
  }
}
